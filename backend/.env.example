PROJECT_NAME="DataSense AI"
API_V1_STR="/api/v1"

# Supabase Postgres Connection String
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Make sure to replace [YOUR-PASSWORD] and set sslmode=require
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Supabase Auth
# Get these from Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_KEY="ey..."

# AI Configuration
# Set ACTIVE_AI_PROVIDER to either "GEMINI" or "NVIDIA"
ACTIVE_AI_PROVIDER="GEMINI"

# Set the model you want to use.
# For Gemini: "gemini-2.5-flash", "gemini-2.5-pro"
# For NVIDIA: "deepseek-ai/deepseek-r1", "meta/llama3-70b-instruct", "moonshotai/kimi-k2.5"
AI_MODEL_NAME="gemini-2.5-flash"

# Google Gemini API Key
# Get this from Google AI Studio
GEMINI_API_KEY="AIzaSy..."

# NVIDIA API Key (Optional: only needed if using ACTIVE_AI_PROVIDER="NVIDIA")
# Get this from build.nvidia.com
NVIDIA_API_KEY="nvapi-..."
